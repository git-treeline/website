---
export interface Worktree {
  project: string;
  branch: string;
  port: number;
  supervisor: string;
  listening: boolean;
}

interface Props {
  worktrees?: Worktree[];
  selectedIndex?: number;
  class?: string;
}

const defaultWorktrees: Worktree[] = [
  { project: 'acme-api', branch: 'main', port: 3000, supervisor: 'running', listening: true },
  { project: 'acme-api', branch: 'feature/auth-v2', port: 3010, supervisor: 'running', listening: true },
  { project: 'acme-api', branch: 'fix/rate-limiting', port: 3020, supervisor: 'not running', listening: false },
  { project: 'acme-web', branch: 'main', port: 3080, supervisor: 'running', listening: true },
  { project: 'acme-web', branch: 'feature/dashboard', port: 3090, supervisor: 'not running', listening: false },
  { project: 'acme-web', branch: 'feature/onboarding', port: 3100, supervisor: 'running', listening: true },
  { project: 'acme-docs', branch: 'main', port: 3050, supervisor: 'not running', listening: false },
  { project: 'shared-ui', branch: 'main', port: 3110, supervisor: 'running', listening: true },
  { project: 'shared-ui', branch: 'feature/dark-mode', port: 3120, supervisor: 'not running', listening: false },
];

const {
  worktrees = defaultWorktrees,
  selectedIndex = 1,
  class: className = '',
} = Astro.props;

const groupedByProject = worktrees.reduce((acc, wt) => {
  if (!acc[wt.project]) acc[wt.project] = [];
  acc[wt.project].push(wt);
  return acc;
}, {} as Record<string, Worktree[]>);

const projectCount = Object.keys(groupedByProject).length;
const runningCount = worktrees.filter(w => w.listening).length;
const selected = worktrees[selectedIndex];
---

<div class={`tui-demo select-none ${className}`}>
  <!-- macOS window chrome -->
  <div class="rounded-lg overflow-hidden shadow-2xl" style="background: #1e2127; max-width: 520px; border: 1px solid #3b4048;">
    
    <!-- Title bar -->
    <div class="flex items-center gap-2 px-3 py-2" style="background: #282c34; border-bottom: 1px solid #3b4048;">
      <div class="flex gap-1.5">
        <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
        <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
        <span class="w-3 h-3 rounded-full bg-[#27c93f]"></span>
      </div>
      <span class="flex-1 text-center text-xs font-mono" style="color: #5c6370;">acme-api — gtl dashboard</span>
    </div>
    
    <!-- Panels -->
    <div class="flex font-mono text-[10px] leading-tight" style="min-height: 220px;">
      <!-- Left panel: worktree list -->
      <div class="w-[40%] p-2 border-r" style="border-color: #56b6c2;">
        <div class="mb-1.5" style="color: #56b6c2; font-size: 9px;">WORKTREES</div>
        <div class="space-y-0">
          {Object.entries(groupedByProject).map(([project, wts]) => (
            <>
              <div class="mt-1 first:mt-0 mb-0.5" style="color: #abb2bf; font-size: 9px;">{project}</div>
              {wts.map((wt) => {
                const isSelected = wt === selected;
                return (
                  <div class={`flex items-center gap-1 py-px pl-0.5 ${isSelected ? 'bg-[#3e4451]' : ''}`}>
                    <span class={`w-1 h-1 rounded-full flex-shrink-0 ${wt.listening ? 'bg-green-400' : 'border border-orange-400'}`}></span>
                    <span style="color: #c678dd; font-size: 9px;">:{wt.port}</span>
                    <span class="truncate" style={`color: ${isSelected ? '#ffffff' : '#abb2bf'}; font-size: 9px;`}>{wt.branch}</span>
                  </div>
                );
              })}
            </>
          ))}
        </div>
      </div>

      <!-- Right panel: detail -->
      <div class="flex-1 p-2" style="border-left: 1px solid #3b4048;">
        {selected && (
          <>
            <div class="mb-2" style="color: #56b6c2; font-size: 9px;">{selected.project} / {selected.branch}</div>
            <div class="space-y-0.5" style="color: #abb2bf; font-size: 9px;">
              <div class="flex">
                <span class="w-16" style="color: #5c6370;">Port</span>
                <span style="color: #e5c07b;">{selected.port}</span>
              </div>
              <div class="flex">
                <span class="w-16" style="color: #5c6370;">Database</span>
                <span style="color: #abb2bf;">acme_dev_auth_v2</span>
              </div>
              <div class="flex">
                <span class="w-16" style="color: #5c6370;">Redis</span>
                <span style="color: #5c6370;">—</span>
              </div>
              <div class="flex">
                <span class="w-16" style="color: #5c6370;">Supervisor</span>
                <span style={`color: ${selected.supervisor === 'running' ? '#98c379' : '#5c6370'};`}>{selected.supervisor}</span>
              </div>
              <div class="flex">
                <span class="w-16" style="color: #5c6370;">Listening</span>
                <span style={`color: ${selected.listening ? '#98c379' : '#e06c75'};`}>{selected.listening ? 'yes' : 'no'}</span>
              </div>
              <div class="flex">
                <span class="w-16" style="color: #5c6370;">Env file</span>
                <span style="color: #abb2bf;">.env.local</span>
              </div>
            </div>
          </>
        )}
      </div>
    </div>

    <!-- Status bar -->
    <div class="px-2 py-1 font-mono" style="background: #282c34; border-top: 1px solid #3b4048; font-size: 9px;">
      <div style="color: #5c6370;">
        {projectCount} projects · {worktrees.length} worktrees · {runningCount} running · serve: <span style="color: #98c379;">active</span>
      </div>
      <div class="flex gap-1.5 flex-wrap" style="color: #5c6370;">
        <span><span style="color: #e5c07b;">s</span>:start/stop</span>
        <span><span style="color: #e5c07b;">o</span>:open</span>
        <span><span style="color: #e5c07b;">r</span>:restart</span>
        <span><span style="color: #e5c07b;">d</span>:release</span>
        <span><span style="color: #e5c07b;">/</span>:filter</span>
        <span><span style="color: #e5c07b;">?</span>:help</span>
        <span><span style="color: #e5c07b;">q</span>:quit</span>
      </div>
    </div>
  </div>
</div>

---
const { label } = Astro.props;
---
<div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-8 py-7 sm:py-6 border-b border-surface-border last:border-b-0">
  <div class="font-mono text-lg sm:text-xl text-accent-light shrink-0 sm:w-72 sm:text-right">{label}</div>
  <div class="text-muted text-base sm:text-lg">
    <slot />
  </div>
</div>

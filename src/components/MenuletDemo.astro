---
export interface Worktree {
  branch: string;
  path?: string;
  ports: number[];
  status: 'running' | 'idle';
}

export interface Project {
  name: string;
  worktrees: Worktree[];
  expanded?: boolean;
}

interface Props {
  projects?: Project[];
  routerStatus?: 'running' | 'stopped';
  runningCount?: number;
  idleCount?: number;
  showUpdate?: boolean;
  class?: string;
}

const defaultProjects: Project[] = [
  {
    name: 'API-DOCS',
    expanded: true,
    worktrees: [
      { branch: 'main', ports: [3000], status: 'running' },
    ],
  },
  {
    name: 'ASSESSMENT-PLATFORM',
    expanded: true,
    worktrees: [
      { branch: 'main', ports: [3080], status: 'running' },
    ],
  },
  {
    name: 'GIT-TREELINE',
    expanded: true,
    worktrees: [
      { branch: 'feature-tui-dashboard', path: 'git-treeline-feature-tui-dashboard', ports: [3010], status: 'running' },
    ],
  },
  {
    name: 'SALT',
    expanded: true,
    worktrees: [
      { branch: 'production', ports: [3090, 3091], status: 'running' },
      { branch: 'staging', path: 'karachi', ports: [3110, 3111], status: 'idle' },
    ],
  },
];

const {
  projects = defaultProjects,
  routerStatus = 'running',
  runningCount = 5,
  idleCount = 8,
  showUpdate = true,
  class: className = '',
} = Astro.props;

const totalWorktrees = (p: Project) => p.worktrees.length;
---

<div class={`menulet-demo select-none ${className}`}>
  <div class="menulet-window rounded-xl overflow-hidden shadow-2xl border border-white/10" style="background: linear-gradient(180deg, #f5f5f7 0%, #e8e8ed 100%); max-width: 340px;">
    
    <!-- Header -->
    <div class="px-4 py-3 flex items-center justify-between border-b border-black/5">
      <span class="text-sm font-semibold text-gray-900">git-treeline</span>
      <div class="flex items-center gap-3 text-xs">
        <span class="text-gray-500 flex items-center gap-1">
          <span class={`w-1.5 h-1.5 rounded-full ${routerStatus === 'running' ? 'bg-gray-400' : 'bg-red-400'}`}></span>
          Router
        </span>
        <span class="text-green-600 flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          {runningCount} up
        </span>
        <span class="text-orange-500 flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full border border-orange-400 bg-transparent"></span>
          {idleCount} idle
        </span>
      </div>
    </div>

    <!-- Project list -->
    <div class="max-h-[400px] overflow-y-auto">
      {projects.map((project) => (
        <div class="border-b border-black/5 last:border-b-0">
          <!-- Project header -->
          <div class="px-4 py-2.5 flex items-center gap-2">
            <svg class={`w-3 h-3 text-gray-400 transition-transform ${project.expanded ? 'rotate-0' : '-rotate-90'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
            <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">{project.name}</span>
            <span class="text-[10px] bg-gray-300/60 text-gray-600 px-1.5 py-0.5 rounded-full">{totalWorktrees(project)}</span>
          </div>

          <!-- Worktrees -->
          {project.expanded !== false && project.worktrees.map((wt) => (
            <div class="px-4 py-2.5 flex items-center gap-3 hover:bg-black/[0.02] transition-colors group">
              <!-- Status indicator -->
              <div class={`w-1 h-8 rounded-full ${wt.status === 'running' ? 'bg-green-500' : 'bg-orange-400'}`}></div>
              
              <!-- Branch info -->
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-gray-900 truncate">{wt.branch}</div>
                {wt.path && (
                  <div class="text-xs text-gray-400 truncate">{wt.path}</div>
                )}
              </div>

              <!-- Ports -->
              <div class="flex items-center gap-1.5">
                <span class="text-xs font-mono bg-gray-200/80 text-gray-600 px-2 py-1 rounded">
                  {wt.ports.join(', ')}
                </span>
                <button class="text-gray-400 hover:text-gray-600 opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <circle cx="12" cy="6" r="1.5"></circle>
                    <circle cx="12" cy="12" r="1.5"></circle>
                    <circle cx="12" cy="18" r="1.5"></circle>
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>

    <!-- Footer -->
    <div class="px-4 py-2.5 flex items-center justify-between border-t border-black/5 bg-white/50">
      <button class="text-xs text-gray-500 hover:text-gray-700 flex items-center gap-1.5 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
        </svg>
        Refresh
      </button>
      <div class="flex items-center gap-2">
        {showUpdate && (
          <button class="text-xs text-green-600 hover:text-green-700 flex items-center gap-1 transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2a10 10 0 1010 10A10 10 0 0012 2zm0 18a8 8 0 118-8 8 8 0 01-8 8zm4-9h-3V8a1 1 0 00-2 0v4a1 1 0 001 1h4a1 1 0 000-2z"></path>
            </svg>
            Update
          </button>
        )}
        <button class="text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="6" r="1.5"></circle>
            <circle cx="12" cy="12" r="1.5"></circle>
            <circle cx="12" cy="18" r="1.5"></circle>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

---
const { label, noHeader = false } = Astro.props;
---
<div class="bg-surface-raised border border-surface-border rounded-lg font-mono text-base leading-relaxed overflow-x-auto">
  {!noHeader && (
    <div class="flex items-center gap-2 px-4 sm:px-5 py-3.5 sm:py-4 border-b border-surface-border min-h-[3rem]">
      <span class="w-3 h-3 rounded-full bg-red-500 shrink-0"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-500 shrink-0"></span>
      <span class="w-3 h-3 rounded-full bg-green-500 shrink-0"></span>
      {label && <span class="text-xs text-muted ml-2">{label}</span>}
    </div>
  )}
  <div class="p-4 sm:p-6">
    <slot />
  </div>
</div>

---
const { heading, subtext, id, level = 2 } = Astro.props;
const Tag = `h${level}` as any;
---
<Tag id={id} class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-balance">
  {heading}
</Tag>
{subtext && <p class="text-base sm:text-lg text-muted max-w-2xl text-balance">{subtext}</p>}

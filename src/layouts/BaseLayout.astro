---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogType?: string;
  keywords?: string;
  activeNav?: 'features' | 'docs' | 'use-cases' | null;
  installHref?: string;
  jsonLd?: string | string[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  keywords,
  activeNav = null,
  installHref = '/#get-started',
  jsonLd,
} = Astro.props;

const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const site = Astro.site ?? new URL('https://git-treeline.dev');
const ogImagePath = ogImage ?? '/og-image.png';
const ogImageAbsolute = ogImagePath.startsWith('http')
  ? ogImagePath
  : new URL(ogImagePath.replace(/^\//, ''), site).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Git Treeline" />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Code+Pro:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <style is:inline>
      html, body { background-color: #0d1117; }
      #site-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; }
    </style>

    <script src="https://cdn.usefathom.com/script.js" data-site="QPFTFHRS" defer></script>

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={block} />
    ))}
  </head>
  <body>
    <nav
      id="site-nav"
      class="fixed top-0 left-0 right-0 z-50 bg-surface transition-colors duration-200"
    >
      <div
        class="max-w-5xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-center gap-3 text-white hover:text-accent-light transition-colors"
        >
          <svg class="w-7 h-7" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="6" fill="#0d1117" stroke="#30363d" stroke-width="1"
            ></rect>
            <text
              x="16"
              y="22"
              font-family="monospace"
              font-weight="700"
              font-size="13"
              fill="#22c55e"
              text-anchor="middle">gtl</text>
          </svg>
          <span class="font-mono text-sm font-semibold hidden sm:inline">git-treeline</span>
        </a>
        <div class="flex items-center gap-3 sm:gap-6">
          <div class="relative group">
            <button
              type="button"
              class={`text-sm flex items-center gap-1 transition-colors ${activeNav === 'features' ? 'text-white' : 'text-muted hover:text-white'}`}
            >
              Features
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div
              class="absolute top-full left-0 mt-2 w-44 bg-surface-raised border border-surface-border rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 py-2 z-50"
            >
              <a
                href="/features/isolation/"
                class="block px-4 py-2 text-sm text-muted hover:text-white hover:bg-surface transition-colors"
                >Isolation</a>
              <a
                href="/features/networking/"
                class="block px-4 py-2 text-sm text-muted hover:text-white hover:bg-surface transition-colors"
                >Networking</a>
              <a
                href="/features/workflows/"
                class="block px-4 py-2 text-sm text-muted hover:text-white hover:bg-surface transition-colors"
                >Workflows</a>
              <a
                href="/features/agents/"
                class="block px-4 py-2 text-sm text-muted hover:text-white hover:bg-surface transition-colors"
                >AI Agents</a>
            </div>
          </div>
          <a
            href="/docs/"
            class={`text-sm transition-colors ${activeNav === 'docs' ? 'text-white' : 'text-muted hover:text-white'}`}
            >Docs</a>
          <a
            href="/use-cases/"
            class={`text-sm transition-colors ${activeNav === 'use-cases' ? 'text-white' : 'text-muted hover:text-white'}`}
            >Use cases</a>
          <a
            href="https://github.com/git-treeline/git-treeline"
            class="text-sm text-muted hover:text-white transition-colors hidden sm:inline"
            >GitHub</a>
          <a
            href={installHref}
            class="text-xs font-mono px-3 sm:px-4 py-2 bg-accent text-surface rounded-md hover:bg-accent-light transition-colors"
            >Install</a>
        </div>
      </div>
    </nav>

    <script is:inline>
      (function () {
        var nav = document.getElementById('site-nav');
        window.addEventListener('scroll', function () {
          nav.classList.toggle('nav-scrolled', window.scrollY > 40);
        });
      })();
    </script>

    <slot />

    <footer>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 pb-10">
        <div
          class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-10 lg:gap-14"
        >
          <nav class="flex-1 min-w-0" aria-label="Footer">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-10 gap-y-8 max-w-lg">
              <div>
                <h3 class="text-xs uppercase tracking-wider text-muted font-medium mb-3">Product</h3>
                <ul class="space-y-2.5">
                  <li>
                    <a
                      href="/features/isolation/"
                      class="text-base text-muted hover:text-white transition-colors">Isolation</a>
                  </li>
                  <li>
                    <a
                      href="/features/networking/"
                      class="text-base text-muted hover:text-white transition-colors">Networking</a>
                  </li>
                  <li>
                    <a
                      href="/features/workflows/"
                      class="text-base text-muted hover:text-white transition-colors">Workflows</a>
                  </li>
                  <li>
                    <a
                      href="/features/agents/"
                      class="text-base text-muted hover:text-white transition-colors">AI Agents</a>
                  </li>
                </ul>
              </div>
              <div>
                <h3 class="text-xs uppercase tracking-wider text-muted font-medium mb-3">Resources</h3>
                <ul class="space-y-2.5">
                  <li>
                    <a href="/docs/" class="text-base text-muted hover:text-white transition-colors"
                      >Documentation</a>
                  </li>
                  <li>
                    <a
                      href="/use-cases/first-time-setup/"
                      class="text-base text-muted hover:text-white transition-colors"
                      >First-time setup</a>
                  </li>
                  <li>
                    <a
                      href="/use-cases/"
                      class="text-base text-muted hover:text-white transition-colors">Use cases</a>
                  </li>
                </ul>
              </div>
              <div class="col-span-2 sm:col-span-1">
                <h3 class="text-xs uppercase tracking-wider text-muted font-medium mb-3">Open source</h3>
                <ul class="space-y-2.5">
                  <li>
                    <a
                      href="https://github.com/git-treeline/git-treeline"
                      class="text-base text-muted hover:text-white transition-colors">GitHub</a>
                  </li>
                  <li>
                    <a
                      href="https://github.com/git-treeline/git-treeline-menulet/releases/latest/download/GitTreelineMenulet.dmg"
                      class="text-base text-muted hover:text-white transition-colors"
                      >Menu bar app</a>
                  </li>
                  <li>
                    <a
                      href="https://github.com/git-treeline/git-treeline/blob/main/LICENSE.txt"
                      class="text-base text-muted hover:text-white transition-colors">MIT License</a>
                  </li>
                </ul>
              </div>
            </div>
          </nav>
          <div class="shrink-0 lg:max-w-[220px]">
            <p class="text-sm font-semibold uppercase tracking-wider text-muted mb-3">Built by</p>
            <a
              href="https://x.com/jonathansimmons"
              target="_blank"
              rel="noopener noreferrer"
              class="text-base font-semibold text-white hover:text-accent-light transition-colors"
              >Jonathan Simmons</a>
          </div>
        </div>
        <div
          class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-t border-surface-border pt-8 text-xs text-muted"
        >
          <a href="/" class="font-mono hover:text-white transition-colors">git-treeline.dev</a>
          <span
            >Open source · <a
              href="https://github.com/git-treeline/git-treeline/blob/main/LICENSE.txt"
              class="hover:text-white transition-colors">MIT License</a></span>
        </div>
      </div>
    </footer>
  </body>
</html>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Terminal from '../../../components/Terminal.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FeatureStrip from '../../../components/FeatureStrip.astro';

const mcpConfigHtml = `{
  "<span class='text-accent-light'>mcpServers</span>": {
    "<span class='text-white'>gtl</span>": {
      "<span class='text-accent-light'>command</span>": "<span class='text-white'>gtl</span>",
      "<span class='text-accent-light'>args</span>": ["<span class='text-white'>mcp</span>"]
    }
  }
}`;

const statusJsonHtml = `<p><span class='text-accent-light'>$</span> <span class='text-white'>gtl status --json</span></p>
<p class='text-muted'>[{</p>
<p class='text-muted'>&nbsp;&nbsp;"<span class='text-accent-light'>branch</span>": "<span class='text-white'>feature-auth</span>",</p>
<p class='text-muted'>&nbsp;&nbsp;"<span class='text-accent-light'>ports</span>": [<span class='text-white'>3010</span>],</p>
<p class='text-muted'>&nbsp;&nbsp;"<span class='text-accent-light'>database</span>": "<span class='text-white'>myapp_dev_feature_auth</span>",</p>
<p class='text-muted'>&nbsp;&nbsp;"<span class='text-accent-light'>listening</span>": <span class='text-accent'>true</span>,</p>
<p class='text-muted'>&nbsp;&nbsp;"<span class='text-accent-light'>supervisor</span>": "<span class='text-accent'>running</span>"</p>
<p class='text-muted'>}]</p>`;
---

<BaseLayout
  title="AI Agents — Git Treeline"
  description="AI coding agents guess ports and break. A built-in MCP server lets agents query real allocations, control the dev server, and inspect config — no shell parsing."
  canonical="https://git-treeline.dev/features/agents/"
  activeNav="features"
>
  <section class="px-4 sm:px-6 pt-28 sm:pt-36 pb-16 sm:pb-20 text-center">
    <p class="text-sm uppercase tracking-wider text-muted mb-4">AI Agents</p>
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6">Agents guess ports and config.<br />They don't have&nbsp;to.</h1>
    <p class="text-base sm:text-lg text-gray-400 max-w-2xl mx-auto">
      A built-in MCP server — Model Context Protocol, the way AI coding agents call tools directly instead of running shell commands — lets agents query real port allocations, control the dev server, and inspect config. Works with any MCP-compatible editor.
    </p>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-28 bg-surface-raised">
    <div class="max-w-4xl mx-auto">
      <div class="text-center">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-balance">Agents don't know about your&nbsp;environment</h2>
        <p class="text-base sm:text-lg text-muted max-w-2xl text-balance mx-auto mb-10">
          Your AI agent creates a worktree and tries to start the server. It doesn't know about port allocation, database cloning, or env files.
        </p>
      </div>
      <div class="max-w-2xl mx-auto">
        <Terminal label="agent without treeline">
          <div class="space-y-2">
            <p><span class="text-accent-light">agent $</span> <span class="text-white">git worktree add ../fix-bug fix-bug</span></p>
            <p><span class="text-accent-light">agent $</span> <span class="text-white">cd ../fix-bug && npm start</span></p>
            <p class="text-red-400">Error: EADDRINUSE :::3000</p>
            <p class="text-muted text-xs mt-1"># Agent tries a random port&hellip;</p>
            <p><span class="text-accent-light">agent $</span> <span class="text-white">PORT=4567 npm start</span></p>
            <p class="text-yellow-400">Warning: DATABASE_URL not set</p>
            <p class="text-muted text-xs mt-1"># Agent guesses at database names&hellip;</p>
            <p><span class="text-accent-light">agent $</span> <span class="text-white">createdb fix_bug_dev</span></p>
            <p class="text-muted text-xs"># Works sometimes. Breaks often.</p>
          </div>
        </Terminal>
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-28">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm uppercase tracking-wider text-muted text-center mb-6">Three lines in your editor config</p>
      <div class="max-w-lg mx-auto mb-10">
        <div class="rounded-lg border border-surface-border overflow-hidden">
          <div class="px-4 py-2.5 border-b border-surface-border flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-accent/50"></span>
            <span class="text-xs font-mono text-muted">MCP config (any MCP-compatible editor)</span>
          </div>
          <pre
            class="px-4 py-4 text-sm leading-relaxed font-mono overflow-x-auto"><code set:html={mcpConfigHtml}></code></pre>
        </div>
      </div>
      <p class="text-base text-muted text-center max-w-lg mx-auto">
        The agent can call <code class="text-accent-light">start</code>, <code class="text-accent-light">stop</code>, <code class="text-accent-light">port</code>, and <code class="text-accent-light">status</code> as structured tool calls — no shell commands, no output parsing. Setup examples for Cursor and Claude Code are in the <a href="/docs/#ai-agents" class="text-accent-light hover:text-accent underline underline-offset-2">docs</a>.
      </p>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-28 bg-surface-raised">
    <div class="max-w-5xl mx-auto">
      <div class="text-center">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-balance">What this makes&nbsp;possible</h2>
        <p class="text-base sm:text-lg text-muted max-w-2xl text-balance mx-auto mb-12">
          AI coding agents are the reason you end up with nine worktrees — three repos, three branches each, all running at the same time. The declarative config and a git hook (installed by <code class="text-accent-light">gtl init</code>) do the heavy lifting. MCP is how agents stay informed about what's running. If you're evaluating agent integration and haven't used MCP before, start here — it's simpler than it looks.
        </p>
      </div>
      <div class="grid gap-10 lg:grid-cols-3 lg:gap-12">
        <BenefitCard>
          <h3 class="text-white font-mono text-lg sm:text-xl mb-3 text-balance">Agents query real ports, not guesses</h3>
          <p class="text-base text-muted leading-relaxed">With the MCP server registered in your editor, an agent calls <code class="text-accent-light">port</code>, <code class="text-accent-light">status</code>, and <code class="text-accent-light">list</code> as structured tools — no shell parsing. <code class="text-accent-light">doctor</code> surfaces the same diagnostic data the CLI uses.</p>
        </BenefitCard>
        <BenefitCard>
          <h3 class="text-white font-mono text-lg sm:text-xl mb-3 text-balance">Agents set up and tear down the same way you do</h3>
          <p class="text-base text-muted leading-relaxed"><code class="text-accent-light">gtl setup .</code> runs the full allocation path (ports, DB, env, <code class="text-white">commands.setup</code>, hooks). <code class="text-accent-light">gtl release . --drop-db</code> frees resources with the same lifecycle hooks — so agents don't invent a parallel cleanup path.</p>
        </BenefitCard>
        <BenefitCard>
          <h3 class="text-white font-mono text-lg sm:text-xl mb-3 text-balance">Multiple agents, multiple sandboxes, no collisions</h3>
          <p class="text-base text-muted leading-relaxed">Each worktree stays isolated: its own ports, database name, and supervisor socket. An orchestrator running three agents in parallel reads deterministic state via <code class="text-accent-light">status --json</code> or MCP <code class="text-white">list</code> instead of scraping stdout.</p>
        </BenefitCard>
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-28">
    <div class="max-w-4xl mx-auto">
      <div class="text-center">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-balance">How agents&nbsp;connect</h2>
        <p class="text-base sm:text-lg text-muted max-w-2xl text-balance mx-auto mb-12">
          Different agents need different interfaces — MCP for editor-native tools, JSON flags for shell-only runners, and committed <code class="text-accent-light">AGENTS.md</code> for static context.
        </p>
      </div>

      <div class="space-y-10">
        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-start">
          <div>
            <h3 class="text-white font-mono text-lg sm:text-xl mb-2">MCP server</h3>
            <p class="text-base text-muted mb-4">
              <code class="text-accent-light">gtl mcp</code> starts a Model Context Protocol server that exposes worktree tools and resources. Agents call <code class="text-white">start</code>, <code class="text-white">stop</code>, <code class="text-white">restart</code>, <code class="text-white">port</code>, <code class="text-white">status</code> as native tool calls — no shell required.
            </p>
            <p class="text-base text-muted">Resources expose <code class="text-white">gtl://allocations</code> and <code class="text-white">gtl://config/user</code> for read access to the full registry and user-level configuration.</p>
          </div>
          <div class="space-y-3">
            <FeatureStrip label="start">Boot the server via the supervisor</FeatureStrip>
            <FeatureStrip label="stop">Stop the running server</FeatureStrip>
            <FeatureStrip label="restart">Restart the server</FeatureStrip>
            <FeatureStrip label="status">Allocation details and supervisor state</FeatureStrip>
            <FeatureStrip label="port">Get the allocated port for this worktree</FeatureStrip>
            <FeatureStrip label="list">All worktrees and their allocations</FeatureStrip>
            <FeatureStrip label="doctor">Diagnose configuration issues</FeatureStrip>
            <FeatureStrip label="db_name">Get the allocated database name</FeatureStrip>
            <FeatureStrip label="config_get">Read a config key (project or user scope)</FeatureStrip>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-start border-t border-surface-border pt-10">
          <div class="md:order-2">
            <h3 class="text-white font-mono text-lg sm:text-xl mb-2">Lifecycle hooks</h3>
            <p class="text-base text-muted mb-4">
              <code class="text-accent-light">gtl setup .</code> and <code class="text-accent-light">gtl release . --drop-db</code> are the boundaries agents call. Inside <code class="text-accent-light">.treeline.yml</code>, optional <code class="text-white">pre_setup</code>, <code class="text-white">post_setup</code>, <code class="text-white">pre_release</code>, and <code class="text-white">post_release</code> run project shell commands—pre-hooks abort on failure; post-hooks warn and continue.
            </p>
            <p class="text-base text-muted">
              Cross-repo URLs use the same contracts as humans: <code class="text-accent-light">{"gtl resolve <project> --json"}</code> or <code class="text-white">{"{resolve:…}"}</code> in env templates.
            </p>
          </div>
          <div class="md:order-1">
            <Terminal label="agent lifecycle">
              <div class="space-y-1">
                <p class="text-muted text-xs"># Create + setup</p>
                <p><span class="text-accent-light">$</span> <span class="text-white">git worktree add ../fix fix-branch</span></p>
                <p><span class="text-accent-light">$</span> <span class="text-white">cd ../fix && gtl setup .</span></p>
                <p class="text-muted text-accent">Resources allocated. Ready.</p>
                <p class="text-muted text-xs mt-3"># &hellip; agent does its work &hellip;</p>
                <p class="text-muted text-xs mt-3"># Teardown</p>
                <p><span class="text-accent-light">$</span> <span class="text-white">gtl release . --drop-db</span></p>
                <p class="text-muted text-accent">Released. Database dropped.</p>
              </div>
            </Terminal>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-start border-t border-surface-border pt-10">
          <div>
            <h3 class="text-white font-mono text-lg sm:text-xl mb-2">Structured output</h3>
            <p class="text-base text-muted mb-3">
              Common commands with <code class="text-accent-light">--json</code> for scripts and agents that do not use MCP:
            </p>
            <ul class="text-base text-muted space-y-1 mb-3">
              <li><code class="text-accent-light">gtl status --json</code> — allocations, runtime health, supervisor state</li>
              <li><code class="text-accent-light">gtl doctor --json</code> — config, allocation, and diagnostic checks</li>
              <li><code class="text-accent-light">gtl port --json</code> — allocated port(s) for the worktree</li>
              <li><code class="text-accent-light">gtl db name --json</code> — allocated database name</li>
              <li><code class="text-accent-light">gtl env --json</code> — env file contents, structured</li>
              <li><code class="text-accent-light">{"gtl resolve <project> --json"}</code> — another project’s base URL from the registry</li>
            </ul>
            <p class="text-base text-muted mb-4">
              MCP is the preferred interface — native tool calls, no shell — but <code class="text-accent-light">--json</code> works for any agent that can run commands.
            </p>
          </div>
          <Terminal>
            <div class="space-y-1" set:html={statusJsonHtml}></div>
          </Terminal>
        </div>

        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-start border-t border-surface-border pt-10">
          <div class="md:order-2">
            <h3 class="text-white font-mono text-lg sm:text-xl mb-2">Agent context files</h3>
            <p class="text-base text-muted mb-4">
              <code class="text-accent-light">gtl init</code> generates an <code class="text-white">AGENTS.md</code> file that provides agents with instructions for setup, teardown, and server management. Any MCP-compatible editor reads it as context — how closely agents follow it depends on the model.
            </p>
          </div>
          <div class="md:order-1">
            <Terminal>
              <div class="space-y-1">
                <p><span class="text-accent-light">$</span> <span class="text-white">gtl init</span></p>
                <p class="text-muted">Created <span class="text-accent">.treeline.yml</span></p>
                <p class="text-muted">Created <span class="text-accent">AGENTS.md</span></p>
                <p class="text-muted text-xs mt-2"># AGENTS.md includes:</p>
                <p class="text-muted text-xs"># - Setup: gtl setup .</p>
                <p class="text-muted text-xs"># - Teardown: gtl release . --drop-db</p>
                <p class="text-muted text-xs"># - Port: gtl port</p>
                <p class="text-muted text-xs"># - Server: gtl start / stop / restart</p>
              </div>
            </Terminal>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-28 bg-surface-raised text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-balance">Connect your&nbsp;agent</h2>
      <p class="text-base text-muted mb-8">Add the MCP config to your editor. Agents can then query ports, control the dev server, and inspect allocations — no shell parsing required.</p>
      <div class="rounded-lg border border-surface-border overflow-hidden max-w-sm mx-auto mb-6">
        <pre
          class="px-4 py-3 text-sm leading-relaxed font-mono overflow-x-auto text-left"><code set:html={mcpConfigHtml}></code></pre>
      </div>
      <a href="/docs/#ai-agents" class="text-sm text-accent-light hover:text-accent underline underline-offset-2">Full agent setup reference &rarr;</a>
    </div>
  </section>
</BaseLayout>

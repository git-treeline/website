---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FeatureDemo from '../components/FeatureDemo.astro';
import SectionHeading from '../components/SectionHeading.astro';
import DashboardCarousel from '../components/DashboardCarousel.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "git-treeline",
  alternateName: "Git Treeline",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux",
  description: "CLI that gives every git worktree its own port, database, and URL. Isolated dev environments for parallel branch development.",
  url: "https://git-treeline.dev",
  downloadUrl: "https://github.com/git-treeline/git-treeline/releases",
  license: "https://opensource.org/licenses/MIT",
  author: { "@type": "Person", name: "Jonathan Simmons", url: "https://x.com/jonathansimmons" },
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
});
---

<BaseLayout
  title="Git Treeline · Isolated dev environments for every git worktree"
  description="Declarative worktree provisioning: ports, databases, routing, env, and lifecycle hooks for every git branch. One CLI, one config file."
  canonical="https://git-treeline.dev"
  installHref="#get-started"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section id="hero" class="flex flex-col items-center text-center px-4 sm:px-6 pt-28 sm:pt-40 md:pt-48 pb-12 sm:pb-24">
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight mb-2 sm:mb-3">git-treeline</h1>
    <p class="hidden sm:block text-base font-mono uppercase tracking-widest text-muted mb-6">Worktree provisioner</p>
    <p class="text-xl md:text-2xl text-accent-light max-w-2xl mb-3 sm:mb-4">Run every branch at the same time</p>
    <p class="text-base sm:text-lg text-gray-400 max-w-2xl mb-6 sm:mb-12 leading-relaxed">
      Declare what each branch needs in one YAML file: ports, databases, routing, env, lifecycle hooks. GTL provisions it. Three features, a bugfix, and a code review, all at&nbsp;once.
    </p>
    <div class="flex flex-col sm:flex-row items-center gap-4 mb-8 w-full max-w-2xl">
      <div class="bg-surface-raised border border-surface-border rounded-lg px-3 sm:px-5 py-2.5 sm:py-3 font-mono text-base flex items-center justify-between gap-3 sm:gap-4 min-w-0 max-w-full overflow-x-auto">
        <code class="text-accent-light whitespace-nowrap text-sm sm:text-base">brew install git-treeline/tap/git-treeline</code>
        <button onclick="navigator.clipboard.writeText('brew install git-treeline/tap/git-treeline')" class="text-muted hover:text-white transition-colors" aria-label="Copy install command">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </button>
      </div>
      <a href="https://github.com/git-treeline/git-treeline" class="inline-flex items-center justify-center gap-3 whitespace-nowrap px-8 py-3.5 border border-surface-border rounded-none text-white hover:border-accent transition-colors">
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>
    <p class="hidden sm:block text-sm text-muted mt-4">
      <span class="font-mono text-white/40 mr-2">v0.38.0</span>
      One-time setup (<code class="text-accent-light">gtl serve install</code>) enables branch-named HTTPS URLs on macOS/Linux.
      <a href="/use-cases/first-time-setup/" class="text-accent-light hover:text-accent underline underline-offset-2">Full walkthrough&nbsp;&rarr;</a>
    </p>
  </section>

  <!-- Problem / Solution -->
  <section id="problem-solution" class="px-4 sm:px-6 py-16 sm:py-28 bg-surface-raised">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-center text-balance">Worktrees are easy to create. Hard&nbsp;to&nbsp;run.</h2>
      <p class="text-base sm:text-lg text-muted max-w-2xl text-balance text-center mx-auto mb-12">
        A git worktree is a separate checkout of your repo in its own directory — <code class="text-accent-light">git worktree add</code> creates one in seconds. But every checkout shares the same ports, databases, and&nbsp;config.
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <Terminal label="without git-treeline">
          <div class="space-y-3">
            <div>
              <p><span class="text-accent-light">~/feature-a $</span> <span class="text-white">npm run dev</span></p>
              <p class="text-muted">&#9656; Ready on http://localhost:3000</p>
            </div>
            <div>
              <p><span class="text-accent-light">~/feature-b $</span> <span class="text-white">bin/dev</span></p>
              <p class="text-red-400">Error: listen EADDRINUSE : :3000</p>
            </div>
            <div>
              <p><span class="text-accent-light">~/feature-b $</span> <span class="text-white">psql -c "CREATE DATABASE myapp_dev"</span></p>
              <p class="text-red-400">ERROR: database "myapp_dev" already exists</p>
            </div>
          </div>
        </Terminal>
        <Terminal label="with git-treeline">
          <div class="space-y-3">
            <div>
              <p><span class="text-accent-light">~ $</span> <span class="text-white">gtl new feature-auth</span></p>
              <p class="text-muted">Creating worktree <span class="text-accent">feature-auth</span></p>
              <p class="text-muted">Allocated port <span class="text-accent">3010</span></p>
              <p class="text-muted">Cloned database <span class="text-accent">myapp_dev_feature_auth</span></p>
              <p class="text-muted">Wrote <span class="text-accent">.env.local</span></p>
              <p class="text-muted">Running setup commands...</p>
              <p class="text-accent mt-1">==> https://myapp-feature-auth.prt.dev</p>
              <p class="text-muted mt-1">named URL via gtl serve (one-time setup)</p>
            </div>
          </div>
        </Terminal>
      </div>
      <p class="text-center text-lg sm:text-xl text-gray-300 mt-10">Your worktrees should be provisioned, not&nbsp;duct&#8209;taped.</p>
    </div>
  </section>

  <!-- Why port 3000 stays free -->
  <section id="port-3000" class="px-4 sm:px-6 py-16 sm:py-28">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-center text-balance">Port 3000 stays free. On&nbsp;purpose.</h2>
      <p class="text-base sm:text-lg text-muted max-w-2xl text-balance text-center mx-auto mb-12">
        OAuth providers, Stripe webhooks, Mapbox, CORS policies &mdash; they&rsquo;re all registered to <code class="text-white">localhost:3000</code>. The moment a second branch takes that port, every integration breaks. Treeline never allocates common ports. It reserves them for the proxy.
      </p>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center max-w-3xl mx-auto mb-12">
        <Terminal>
          <div class="space-y-2">
            <p><span class="text-accent-light">$</span> <span class="text-white">gtl proxy 3000</span></p>
            <p class="text-muted">Proxying <span class="text-accent">:3000</span> &rarr; <span class="text-accent">:4010</span> <span class="text-muted">(feature-auth)</span></p>
            <p class="text-muted text-sm mt-3"># OAuth callback &rarr; :4010</p>
            <p class="text-muted text-sm"># Stripe webhook &rarr; :4010</p>
            <p class="text-muted text-sm"># Mapbox origin  &rarr; :4010</p>
          </div>
        </Terminal>
        <div class="space-y-5">
          <div class="border-l-2 border-accent/40 pl-4">
            <p class="text-white font-medium mb-1">Configure once, never again</p>
            <p class="text-base text-muted">Register <code class="text-accent-light">localhost:3000/callback</code> in your OAuth dashboard. Register <code class="text-accent-light">localhost:3000/webhooks</code> in Stripe. Done.</p>
          </div>
          <div class="border-l-2 border-accent/40 pl-4">
            <p class="text-white font-medium mb-1">Switch what&rsquo;s behind it</p>
            <p class="text-base text-muted"><code class="text-accent-light">gtl proxy 3000</code> routes to whichever worktree you&rsquo;re in. The external world sees the same origin. You rotate what&rsquo;s behind it.</p>
          </div>
          <div class="border-l-2 border-accent/40 pl-4">
            <p class="text-white font-medium mb-1">Branch URLs for everything else</p>
            <p class="text-base text-muted">Your browser uses <code class="text-accent-light">myapp-feature.prt.dev</code>. Third-party services use port 3000. Both work at the same time.</p>
          </div>
        </div>
      </div>

      <p class="text-center">
        <a href="/use-cases/integrations-urls/" class="inline-block text-sm font-mono font-semibold px-5 py-2.5 rounded-md border border-accent/40 text-accent-light hover:bg-accent/10 hover:border-accent transition-colors">How this works with OAuth, Stripe, and more &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Feature highlights -->
  <section id="features" class="px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">

      <div class="pt-20 sm:pt-28 pb-4 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-4">Four pillars, one config file</h2>
        <p class="text-base sm:text-lg text-muted max-w-2xl mx-auto">Everything is driven by <code class="text-accent-light">.treeline.yml</code> at the root of your repo. Each feature page goes deeper: config options, terminal walkthroughs, and edge cases.</p>
      </div>

      <!-- Isolation -->
      <FeatureCard title="Two branches. Two apps. Zero conflicts." link="/features/isolation/" linkText="How isolation works →">
        <p>Not containers — separate ports, databases, and config for every worktree. Declare what each branch needs in <code class="text-accent-light">.treeline.yml</code> and a git hook installed by <code class="text-accent-light">gtl init</code> allocates resources on every checkout.</p>
        <Fragment slot="demo">
          <p class="text-base uppercase tracking-wider text-accent-light mb-2">Environment isolation</p>
          <Terminal>
            <div class="space-y-2">
              <p><span class="text-accent-light">$</span> <span class="text-white">gtl new feature-auth</span></p>
              <p class="text-muted">Allocated port <span class="text-accent">3010</span></p>
              <p class="text-muted">Cloned database <span class="text-accent">myapp_dev_feature_auth</span></p>
              <p class="text-muted">Wrote <span class="text-accent">.env.local</span></p>
              <p class="text-accent">==> https://myapp-feature-auth.prt.dev</p>
              <p class="text-muted">named URL via gtl serve</p>
            </div>
          </Terminal>
        </Fragment>
      </FeatureCard>

      <!-- Networking -->
      <FeatureCard title="The URL follows the branch, not the port." link="/features/networking/" linkText="Networking in depth →" reversed>
        <p>Your app still listens on <code class="text-accent-light">localhost:{'{port}'}</code> but the router gives every branch a named HTTPS URL so you don&rsquo;t need to remember which port is which. Port 3000 stays free for <code class="text-accent-light">gtl proxy</code> so OAuth, Stripe, and CORS stay configured to a single origin.</p>
        <Fragment slot="demo">
          <p class="text-base uppercase tracking-wider text-accent-light mb-2">Networking</p>
          <FeatureDemo label="Networking">
            <div class="flex flex-col items-stretch gap-6 sm:gap-8 py-1">
              <div class="text-center w-full min-w-0">
                <code class="font-mono text-base sm:text-lg text-muted block mb-2 whitespace-nowrap overflow-x-auto py-2 sm:py-2.5">localhost:3010</code>
                <p class="text-sm text-muted uppercase tracking-wider mt-1">Ephemeral port</p>
              </div>
              <span class="block text-center text-2xl text-muted py-1" aria-hidden="true">&darr;</span>
              <div class="text-center w-full min-w-0">
                <code class="font-mono text-base sm:text-lg text-white block mb-2 whitespace-nowrap overflow-x-auto py-2 sm:py-2.5 leading-snug">
                  <span class="text-muted">https://</span><span class="text-accent-light">myapp-feature-auth.prt.dev</span>
                </code>
                <p class="text-sm text-muted uppercase tracking-wider mt-1">HTTPS URL for this branch</p>
              </div>
            </div>
          </FeatureDemo>
        </Fragment>
      </FeatureCard>

      <!-- Workflows -->
      <FeatureCard title="Type a PR number. Get a running app." link="/features/workflows/" linkText="Review and supervisor →">
        <p><code class="text-accent-light">gtl review 42</code> fetches a PR and boots the app in one command. A lightweight process supervisor handles start, stop, and restart — no PID files, no signal guessing.</p>
        <Fragment slot="demo">
          <p class="text-base uppercase tracking-wider text-accent-light mb-2">Workflows</p>
          <FeatureDemo label="gtl review">
            <div class="space-y-0 border-l-2 border-surface-border pl-4">
              <p class="mb-3"><span class="text-accent-light">$</span> <span class="text-white">gtl review 42 --start</span></p>
              <div class="flex items-start gap-3 py-2 relative">
                <span class="text-accent text-sm font-bold shrink-0 mt-0.5">&#10003;</span>
                <span class="text-base text-muted min-w-0">Fetched PR <strong class="text-white">#42</strong></span>
              </div>
              <div class="flex items-start gap-3 py-2 relative">
                <span class="text-accent text-sm font-bold shrink-0 mt-0.5">&#10003;</span>
                <span class="text-base text-muted min-w-0">Created worktree, allocated port <strong class="text-white">3020</strong></span>
              </div>
              <div class="flex items-start gap-3 py-2 relative">
                <span class="text-accent text-sm font-bold shrink-0 mt-0.5">&#10003;</span>
                <span class="text-base text-muted min-w-0">Cloned database, ran setup</span>
              </div>
              <div class="flex items-start gap-3 py-2 relative">
                <span class="text-accent text-sm font-bold shrink-0 mt-0.5">&#10003;</span>
                <span class="text-base text-muted min-w-0">Server running</span>
              </div>
              <div class="flex items-start gap-3 pt-2 pb-0 relative">
                <span class="text-accent font-mono font-bold shrink-0 mt-0.5">&rarr;</span>
                <span class="text-base font-mono text-accent min-w-0">https://myapp-pr-42.prt.dev</span>
              </div>
              <p class="text-muted text-sm mt-1 pl-7">named URL via gtl serve</p>
            </div>
          </FeatureDemo>
        </Fragment>
      </FeatureCard>

      <!-- AI Agents -->
      <FeatureCard title="Agents guess ports and config. They don't have to." link="/features/agents/" linkText="Agent integration →" reversed>
        <p>A built-in MCP server — the protocol AI coding agents use to call tools — lets agents query real port allocations, control the dev server, and inspect config. Works with any MCP-compatible editor.</p>
        <Fragment slot="demo">
          <p class="text-base uppercase tracking-wider text-accent-light mb-2">AI Agents</p>
          <FeatureDemo label="MCP config">
            <pre class="m-0 text-sm leading-relaxed font-mono overflow-x-auto"><code>{`{
  "`}<span class="text-accent-light">mcpServers</span>{`": {
    "`}<span class="text-white">gtl</span>{`": {
      "`}<span class="text-accent-light">command</span>{`": "`}<span class="text-white">gtl</span>{`",
      "`}<span class="text-accent-light">args</span>{`": ["`}<span class="text-white">mcp</span>{`"]
    }
  }
}`}</code></pre>
          </FeatureDemo>
        </Fragment>
      </FeatureCard>

    </div>
  </section>

  <!-- Trust -->
  <div class="px-4 sm:px-6 py-10 sm:py-14 bg-surface-raised">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-6 text-sm text-muted leading-relaxed max-w-3xl mx-auto">
      <div class="border-l-2 border-accent/40 pl-4 py-1">
        <strong class="text-white font-semibold block mb-1 text-[0.9375rem]">No runtime dependency</strong> CLI-driven, nothing running in your app.
      </div>
      <div class="border-l-2 border-accent/40 pl-4 py-1">
        <strong class="text-white font-semibold block mb-1 text-[0.9375rem]">No lock-in</strong> A config file, not a library. Remove it and nothing breaks.
      </div>
      <div class="border-l-2 border-accent/40 pl-4 py-1">
        <strong class="text-white font-semibold block mb-1 text-[0.9375rem]">Zero bundle impact</strong> Nothing ships to production. Dev tooling only.
      </div>
      <div class="border-l-2 border-accent/40 pl-4 py-1">
        <strong class="text-white font-semibold block mb-1 text-[0.9375rem]">Opt-in per developer</strong> Works when installed, invisible when it isn&rsquo;t.
      </div>
    </div>
  </div>

  <!-- Dashboards: Menu bar + TUI carousel -->
  <section class="px-4 sm:px-6 py-16 sm:py-24">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-4 text-balance">See everything running</h2>
        <p class="text-base sm:text-lg text-muted max-w-2xl mx-auto">
          Two ways to view your worktrees: a macOS menu bar app for quick access, or a full-screen terminal dashboard for keyboard-driven control.
        </p>
      </div>
      <DashboardCarousel />
    </div>
  </section>

  <!-- Scenarios -->
  <section class="px-4 sm:px-6 py-16 sm:py-24 bg-surface-raised">
    <div class="max-w-3xl mx-auto text-center mb-10 sm:mb-12">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-balance">Solving real problems</h2>
      <p class="text-muted text-base sm:text-lg leading-relaxed">Detailed walkthroughs for the scenarios that break multi-branch development.</p>
    </div>
    <div class="max-w-4xl mx-auto grid sm:grid-cols-3 gap-5 sm:gap-6">
      <a href="/use-cases/first-time-setup/" class="group block rounded-lg border border-surface-border bg-surface-raised p-5 sm:p-6 hover:border-accent/40 transition-colors text-left">
        <p class="text-xs uppercase tracking-wider text-accent-light mb-2 font-mono">Guide</p>
        <h3 class="text-white font-mono text-base mb-2 group-hover:text-accent-light transition-colors">First-time setup</h3>
        <p class="text-base text-muted leading-relaxed">Install, configure, and create your first isolated worktree. The full walkthrough.</p>
      </a>
      <a href="/use-cases/integrations-urls/" class="group block rounded-lg border border-surface-border bg-surface-raised p-5 sm:p-6 hover:border-accent/40 transition-colors text-left">
        <p class="text-xs uppercase tracking-wider text-accent-light mb-2 font-mono">Networking</p>
        <h3 class="text-white font-mono text-base mb-2 group-hover:text-accent-light transition-colors">Why port 3000 stays free</h3>
        <p class="text-base text-muted leading-relaxed">OAuth, Stripe, and CORS all expect <code class="text-accent-light">localhost:3000</code>. Here&rsquo;s why that still works.</p>
      </a>
      <a href="/use-cases/database-per-branch/" class="group block rounded-lg border border-surface-border bg-surface-raised p-5 sm:p-6 hover:border-accent/40 transition-colors text-left">
        <p class="text-xs uppercase tracking-wider text-accent-light mb-2 font-mono">Isolation</p>
        <h3 class="text-white font-mono text-base mb-2 group-hover:text-accent-light transition-colors">Database per branch</h3>
        <p class="text-base text-muted leading-relaxed">Clone from a template in seconds, seed from hooks, or copy a SQLite file.</p>
      </a>
    </div>
    <p class="text-center mt-8">
      <a href="/use-cases/" class="text-sm font-mono text-accent-light hover:text-accent transition-colors">All scenarios &rarr;</a>
    </p>
  </section>

  <!-- Install -->
  <section id="get-started" class="px-4 sm:px-6 py-16 sm:py-28 bg-surface-raised text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-mono font-bold text-white mb-6 sm:mb-4 text-balance">Every branch, fully provisioned</h2>
      <div class="bg-surface-raised border border-surface-border rounded-lg px-3 sm:px-5 py-2.5 sm:py-3 font-mono text-base flex items-center justify-center gap-3 sm:gap-4 min-w-0 max-w-full overflow-x-auto mb-4">
        <code class="text-accent-light whitespace-nowrap text-sm sm:text-base">brew install git-treeline/tap/git-treeline</code>
        <button type="button" onclick="navigator.clipboard.writeText('brew install git-treeline/tap/git-treeline')" class="text-muted hover:text-white transition-colors shrink-0" aria-label="Copy install command">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </button>
      </div>
      <p class="text-base text-muted mb-10">Also <code class="text-accent-light">go install</code> or a <a href="https://github.com/git-treeline/git-treeline/releases" class="text-accent-light hover:text-accent underline underline-offset-2">release binary</a>.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">

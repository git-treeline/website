---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Terminal from '../../components/Terminal.astro';

const reference = [
  { href: '/docs/getting-started/', title: 'Getting started', desc: 'Install, initialize, and create your first worktree.' },
  { href: '/docs/configuration/', title: 'Configuration', desc: 'Every .treeline.yml field, token, and user config key.' },
  { href: '/docs/cli/', title: 'CLI reference', desc: 'Every command with flags and behavior notes.' },
  { href: '/docs/troubleshooting/', title: 'Troubleshooting', desc: 'Common issues by symptom with fixes.' },
];

const guides = [
  { href: '/docs/lifecycle/', title: 'Lifecycle', desc: 'What happens at each step: new, setup, start, release.' },
  { href: '/docs/hooks/', title: 'Hooks', desc: 'Setup, release, and start hooks for provisioning.' },
  { href: '/docs/networking/', title: 'Networking', desc: 'Ports, HTTPS router, aliases, proxy, and tunnels.' },
  { href: '/docs/database/', title: 'Database', desc: 'Per-worktree Postgres cloning, SQLite, and naming.' },
  { href: '/docs/editor/', title: 'Editor', desc: 'Window titles, title bar colors, and IDE behavior.' },
  { href: '/docs/resolve/', title: 'Resolve', desc: 'Connect services across repos with env tokens.' },
  { href: '/docs/supervisor/', title: 'Supervisor', desc: 'Process supervisor, remote restart, and TUI dashboard.' },
  { href: '/docs/agents/', title: 'AI agents', desc: 'MCP server, structured output, and context files.' },
];
---

<DocsLayout
  title="Docs — Git Treeline"
  description="Git Treeline documentation: getting started, guides, configuration, CLI reference, and troubleshooting."
  canonical="https://git-treeline.dev/docs/"
>
  <div class="pt-20 sm:pt-24 pb-16 sm:pb-20 px-4 sm:px-6 lg:px-0">

    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-4">Documentation</h1>
    <p class="text-base sm:text-lg text-muted max-w-2xl mb-8">
      Git Treeline is a CLI that provisions isolated dev environments for every git worktree.
      You declare what each branch needs in a single YAML file, and GTL handles ports, databases, routing, env vars, and lifecycle hooks.
    </p>

    <div class="max-w-lg mb-8">
      <Terminal label=".treeline.yml">
        <pre class="text-sm"><span class="text-accent-light">commands</span><span class="text-muted">:</span>
  <span class="text-accent-light">start</span><span class="text-muted">:</span> <span class="text-white">bin/dev</span>
  <span class="text-accent-light">setup</span><span class="text-muted">:</span> <span class="text-white">bin/setup</span>

<span class="text-accent-light">database</span><span class="text-muted">:</span>
  <span class="text-accent-light">adapter</span><span class="text-muted">:</span> <span class="text-white">postgresql</span>
  <span class="text-accent-light">template</span><span class="text-muted">:</span> <span class="text-white">myapp_development</span></pre>
      </Terminal>
    </div>

    <p class="text-sm text-muted max-w-2xl mb-10">
      That config gives every worktree its own port, database, HTTPS URL, and supervised dev server.
      The guides below explain each subsystem in detail. Start here if you're new:
    </p>

    <a
      href="/docs/getting-started/"
      class="inline-flex items-center gap-2 text-sm font-mono px-5 py-2.5 bg-accent text-surface rounded-md hover:bg-accent-light transition-colors mb-14"
    >
      Get started
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>

    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-1">Reference</h2>
      <p class="text-sm text-muted mb-4">Installation, configuration schema, CLI commands, and common fixes.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {reference.map((item) => (
          <a href={item.href} class="block p-4 rounded-lg border border-surface-border hover:border-accent/40 transition-colors group">
            <p class="text-white font-medium group-hover:text-accent-light transition-colors">{item.title}</p>
            <p class="text-xs text-muted mt-0.5">{item.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-white mb-1">Guides</h2>
      <p class="text-sm text-muted mb-4">Deep dives into how each part of the system works.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {guides.map((item) => (
          <a href={item.href} class="block p-4 rounded-lg border border-surface-border hover:border-accent/40 transition-colors group">
            <p class="text-white font-medium group-hover:text-accent-light transition-colors">{item.title}</p>
            <p class="text-xs text-muted mt-0.5">{item.desc}</p>
          </a>
        ))}
      </div>
    </section>

  </div>
</DocsLayout>

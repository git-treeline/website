---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MenuletDemo from '../../components/MenuletDemo.astro';

const features = [
  {
    title: 'All worktrees at a glance',
    description: 'See every running and idle worktree grouped by project. Status indicators show what\'s up and what\'s waiting.',
  },
  {
    title: 'One-click open',
    description: 'Click any worktree to open its URL in your browser. No need to remember ports or type URLs.',
  },
  {
    title: 'Router status',
    description: 'See if the HTTPS router is running and how many worktrees are active. Green means go.',
  },
  {
    title: 'Quick actions',
    description: 'Start, stop, or restart any worktree from the menu. Open in Finder or your editor.',
  },
];
---

<BaseLayout
  title="Menu Bar App — Git Treeline"
  description="The Git Treeline menu bar app for macOS. See all your worktrees, their ports, and open any branch URL with a click."
  canonical="https://git-treeline.dev/menulet/"
>
  <section class="px-4 sm:px-6 pt-28 sm:pt-36 pb-16 sm:pb-20">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm uppercase tracking-wider text-muted mb-3 font-mono">macOS menu bar app</p>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6">Every worktree. One&nbsp;click&nbsp;away.</h1>
          <p class="text-base sm:text-lg text-gray-400 mb-8 leading-relaxed">
            The menu bar app shows all your worktrees grouped by project. See which branches are running, their ports, and open any URL with a click. When you're running six worktrees across three repos, this is faster than remembering URLs.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <a href="https://github.com/git-treeline/git-treeline-menulet/releases/latest/download/GitTreelineMenulet.dmg" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-accent text-surface text-base font-mono font-semibold hover:bg-accent-light transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              Download for Mac
            </a>
            <a href="https://github.com/git-treeline/git-treeline-menulet" class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-surface-border text-white text-base font-mono hover:border-accent/40 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              View on GitHub
            </a>
          </div>
          <p class="text-sm text-muted">
            Requires macOS 13+. The CLI (<code class="text-accent-light">gtl</code>) must be installed for the app to read allocations.
          </p>
        </div>
        <div class="flex justify-center lg:justify-end">
          <MenuletDemo />
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-24 bg-surface-raised">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-10 text-center">What you get</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        {features.map((feature) => (
          <div class="border-l-2 border-accent/40 pl-5">
            <h3 class="text-white font-semibold text-lg mb-2">{feature.title}</h3>
            <p class="text-base text-muted leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-24">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-6 text-center">How it works</h2>
      <p class="text-base sm:text-lg text-muted text-center mb-10 leading-relaxed">
        The menu bar app reads from the same allocation registry the CLI uses. No separate configuration. If <code class="text-accent-light">gtl status</code> shows it, the menu bar shows it.
      </p>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-accent flex items-center justify-center font-mono font-bold text-sm">1</span>
          <div>
            <p class="text-white font-medium mb-1">Install the CLI</p>
            <p class="text-muted">The menu bar app depends on the CLI for allocation data. Install it first with <code class="text-accent-light">brew install git-treeline/tap/git-treeline</code>.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-accent flex items-center justify-center font-mono font-bold text-sm">2</span>
          <div>
            <p class="text-white font-medium mb-1">Download the app</p>
            <p class="text-muted">Grab the DMG, drag to Applications, and launch. It lives in your menu bar next to the clock.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-accent flex items-center justify-center font-mono font-bold text-sm">3</span>
          <div>
            <p class="text-white font-medium mb-1">Click to see your worktrees</p>
            <p class="text-muted">The app shows all registered worktrees grouped by project. Click any row to open its URL. That's it.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-16 sm:py-24 bg-surface-raised text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white mb-4">Ready to try it?</h2>
      <p class="text-base text-muted mb-8">Download the app and see all your worktrees in your menu bar.</p>
      <a href="https://github.com/git-treeline/git-treeline-menulet/releases/latest/download/GitTreelineMenulet.dmg" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-md bg-accent text-surface text-base font-mono font-semibold hover:bg-accent-light transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        Download for Mac
      </a>
    </div>
  </section>
</BaseLayout>
